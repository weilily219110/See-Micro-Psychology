# Admin 登录配置
ADMIN_EMAIL=admin@jianweiixinli.com
# 使用 bcrypt hash 后的密码，运维人员可通过以下命令生成：
# node -e "const bcrypt = require('bcrypt'); bcrypt.hash('your-password', 10).then(hash => console.log(hash))"
ADMIN_PASSWORD_HASH=

# JWT Secret（生产环境必须修改）
JWT_SECRET=jianwei-admin-secret-key-change-in-production

# 数据库
DATABASE_URL=postgresql://user:password@host:5432/jianwei

# Redis
REDIS_URL=redis://localhost:6379

# 端口
PORT=3001
